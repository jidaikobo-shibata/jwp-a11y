{
  "name": "jidaikobo/a11yc",
  "description": "Static accessibility checker core for A11YC",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.3",
    "guzzlehttp/guzzle": "^7.15.1",
    "symfony/polyfill-intl-idn": "^1.38.1"
  },
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "phpstan/phpstan": "^2.2",
    "phpunit/phpunit": "^12.5.22",
    "slevomat/coding-standard": "^8.30",
    "symfony/yaml": "^7.4",
    "squizlabs/php_codesniffer": "^4.0.1"
  },
  "autoload": {
    "psr-4": {
      "Jidaikobo\\A11yc\\": "src/"
    }
  },
  "scripts": {
    "compile-resources": "@php bin/compile-resources.php",
    "phpstan": "phpstan analyse -c phpstan.neon.dist",
    "phpcs": "phpcs --standard=phpcs.xml.dist",
    "phpunit": "phpunit -c phpunit.xml.dist"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
